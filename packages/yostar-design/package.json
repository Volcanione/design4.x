{
  "name": "@yo-star/yostar-design",
  "version": "0.1.0",
  "description": "Yostar Design Vue components based on Ant Design Vue 4.x.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/yostar-design.umd.cjs",
  "module": "./dist/yostar-design.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/yostar-design.es.js",
      "require": "./dist/yostar-design.umd.cjs"
    },
    "./style.css": "./dist/yostar-design.css",
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./button/style.css": "./dist/button/style.css",
    "./cascader": {
      "types": "./dist/components/cascader/index.d.ts",
      "import": "./dist/cascader/index.js"
    },
    "./cascader/style.css": "./dist/cascader/style.css",
    "./checkbox": {
      "types": "./dist/components/checkbox/index.d.ts",
      "import": "./dist/checkbox/index.js"
    },
    "./checkbox/style.css": "./dist/checkbox/style.css",
    "./config-provider": {
      "types": "./dist/components/config-provider/index.d.ts",
      "import": "./dist/config-provider/index.js"
    },
    "./config-provider/style.css": "./dist/config-provider/style.css",
    "./date-picker": {
      "types": "./dist/components/date-picker/index.d.ts",
      "import": "./dist/date-picker/index.js"
    },
    "./date-picker/style.css": "./dist/date-picker/style.css",
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/input/index.js"
    },
    "./input/style.css": "./dist/input/style.css",
    "./input-number": {
      "types": "./dist/components/input-number/index.d.ts",
      "import": "./dist/input-number/index.js"
    },
    "./input-number/style.css": "./dist/input-number/style.css",
    "./radio": {
      "types": "./dist/components/radio/index.d.ts",
      "import": "./dist/radio/index.js"
    },
    "./radio/style.css": "./dist/radio/style.css",
    "./select": {
      "types": "./dist/components/select/index.d.ts",
      "import": "./dist/select/index.js"
    },
    "./select/style.css": "./dist/select/style.css",
    "./space": {
      "types": "./dist/components/space/index.d.ts",
      "import": "./dist/space/index.js"
    },
    "./space/style.css": "./dist/space/style.css",
    "./switch": {
      "types": "./dist/components/switch/index.d.ts",
      "import": "./dist/switch/index.js"
    },
    "./switch/style.css": "./dist/switch/style.css",
    "./time-picker": {
      "types": "./dist/components/time-picker/index.d.ts",
      "import": "./dist/time-picker/index.js"
    },
    "./time-picker/style.css": "./dist/time-picker/style.css",
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && node --max-old-space-size=4096 ../../node_modules/vue-tsc/bin/vue-tsc.js -p tsconfig.build.json --noEmit && vite build && vite build --config vite.config.subpaths.ts && node --max-old-space-size=4096 ../../node_modules/typescript/bin/tsc -p tsconfig.build.json --emitDeclarationOnly && node scripts/copy-styles.mjs",
    "typecheck": "node --max-old-space-size=4096 ../../node_modules/vue-tsc/bin/vue-tsc.js -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "ant-design-vue": ">=4.0.0 <5.0.0",
    "vue": ">=3.4.0 <4.0.0"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "dayjs": "^1.11.21"
  },
  "devDependencies": {
    "ant-design-vue": "^4.2.6",
    "vue": "^3.5.13"
  }
}
